{
  email ops@indiebox.ai
}

(security_headers) {
  header {
    -Server
    X-Content-Type-Options "nosniff"
    X-Frame-Options "DENY"
    Referrer-Policy "no-referrer"
    Permissions-Policy "accelerometer=(), camera=(), geolocation=(), gyroscope=(), microphone=(), payment=(), usb=()"
    Cross-Origin-Opener-Policy "same-origin"
    Cross-Origin-Resource-Policy "same-origin"
    Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; img-src 'self' data: https:; font-src 'self' https://fonts.gstatic.com data:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; script-src 'self' 'unsafe-inline'; connect-src 'self'; form-action 'self' https://www.mollie.com https://*.mollie.com;"
  }
}

(tls_security_headers) {
  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
  }
}

(admin_basic_auth) {
  basic_auth {
    {$ADMIN_BASIC_AUTH_USER} {$ADMIN_BASIC_AUTH_HASH}
  }
}

:80 {
  redir https://{host}{uri} 308
}

staging.indiebox.ai {
  import security_headers
  import tls_security_headers

  @adminPages path /admin* /en/admin*
  handle @adminPages {
    import admin_basic_auth
    root * /srv/staging.indiebox/site
    encode zstd gzip
    file_server
  }

  handle /api/* {
    request_header X-Proxy-Auth {$PROXY_INTERNAL_TOKEN}
    reverse_proxy backend-staging:8080
  }

  handle /mail/* {
    reverse_proxy backend-staging:8080
  }

  # bb relaunch — staging preview
  handle /bb/staging/* {
    uri strip_prefix /bb/staging
    root * /srv/bb-staging/site
    encode zstd gzip
    file_server
  }

  root * /srv/staging.indiebox/site
  encode zstd gzip
  file_server

  handle_errors {
    root * /srv/staging.indiebox/site
    @404 expression {http.error.status_code} == 404
    handle @404 {
      @en expression `{http.request.orig_uri}.startsWith("/en")`
      handle @en {
        rewrite * /en/404.html
        file_server
      }
      handle {
        rewrite * /404.html
        file_server
      }
    }
  }
}

docs.indiebox.ai {
  import security_headers
  import tls_security_headers

  root * /srv/site
  encode zstd gzip

  @docsRoot path /
  rewrite @docsRoot /docs/index.html
  try_files /docs{path} {path}

  file_server
}

indiebox.ai, www.indiebox.ai {
  import security_headers
  import tls_security_headers

  @adminPages path /admin* /en/admin*
  handle @adminPages {
    import admin_basic_auth
    root * /srv/site
    encode zstd gzip
    file_server
  }

  handle /api/* {
    request_header X-Proxy-Auth {$PROXY_INTERNAL_TOKEN}
    reverse_proxy backend-live:8080
  }

  handle /mail/* {
    reverse_proxy backend-live:8080
  }

  root * /srv/site
  encode zstd gzip
  file_server

  handle_errors {
    root * /srv/site
    @404 expression {http.error.status_code} == 404
    handle @404 {
      @en expression `{http.request.orig_uri}.startsWith("/en")`
      handle @en {
        rewrite * /en/404.html
        file_server
      }
      handle {
        rewrite * /404.html
        file_server
      }
    }
  }
}

# ─────────────────────────────────────────────────────────────────────────────
# brainbot relaunch (bb-relaunch-web-2026). These share this Caddy instance and
# host. They MUST live here: push-stack.sh overwrites this whole file, so any
# vhost missing here is dropped on the next deploy. Site content is deployed
# separately from the bb repo via its own push-site.sh into /srv/bb-*/site.
# ─────────────────────────────────────────────────────────────────────────────

staging.brainbot.com {
  import security_headers
  import tls_security_headers

  root * /srv/bb-staging/site
  encode zstd gzip
  file_server
}

brainbot.com {
  import security_headers
  import tls_security_headers

  root * /srv/bb-live/site
  encode zstd gzip

  # legacy WordPress slug redirects (bb repo docs/site.md)
  redir /services /loesungen permanent
  redir /development /loesungen permanent
  redir /smart-contract-audits /loesungen permanent
  redir /smart-contract-audits-landing /loesungen permanent
  redir /development-landing /loesungen permanent
  redir /consulting /wie-wir-arbeiten permanent
  redir /venture-builder / permanent
  redir /founder-in-residence / permanent
  redir /web3-founder-in-residence / permanent
  redir /ventures / permanent
  redir /hackathons / permanent
  redir /dappwatcher-explainer-video / permanent
  redir /web3-jobs /ueber-brainbot permanent
  redir /web3-careers /ueber-brainbot permanent
  redir /thank-you /kontakt permanent
  redir /imprint /impressum permanent
  redir /privacy-policy /datenschutz permanent
  redir /cookie-policy-eu /datenschutz permanent

  try_files {path} {path}/ {path}.html
  file_server
}

www.brainbot.com {
  import security_headers
  import tls_security_headers
  redir https://brainbot.com{uri} permanent
}
